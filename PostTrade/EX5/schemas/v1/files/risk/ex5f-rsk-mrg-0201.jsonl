{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:a5x:ex5:schema:v1:risk:ex5f-rsk-mrg-02",
  "$metadata": {
    "domain": "risk",
    "schemaId": "urn:a5x:ex5:schema:v1:risk:ex5f-rsk-mrg-02"
  },
  "title": "Instrument Margin Rate",
  "description": "Margin or rate calculated for an instrument",
  "type": "object",
  "properties": {
    "financialInstrumentIdentification": {
      "$ref": "../../objects/business/InstrumentIdentification.json",
      "description": "Identification of the financial instrument"
    },
    "tickerSymbol": {
      "type": "string",
      "maxLength": 35,
      "minLength": 1,
      "description": "Symbol of the instrument"
    },
    "currency": {
      "$ref": "../../objects/business/ExternalCodeTextList.json",
      "description": "Currency for which the fee is calculated",
      "$comment": "Consult External Code List table ExternalCurrencyCode"
    },
    "marketPrice": {
      "$ref": "../../types/DecimalNumber.json",
      "description": "Market price of the instrument, up to 2 decimal places"
    },
    "collateralMarginRate": {
      "$ref": "../../types/DecimalNumber.json",
      "description": "Margin rate in percentage (0-100), up to 4 decimal places"
    },
    "riskPositionValueLong": {
      "$ref": "../../objects/business/MonetaryValue.json",
      "description": "Value of the purchased position considered for risk"
    },
    "riskPositionValueShort": {
      "$ref": "../../objects/business/MonetaryValue.json",
      "description": "Value of the sold position considered for risk"
    }
  },
  "required": [
    "financialInstrumentIdentification",
    "tickerSymbol",
    "currency"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "financialInstrumentIdentification": {
        "id": "100000000000001",
        "source": "8",
        "exchange": "A5X"
      },
      "tickerSymbol": "PETR4",
      "currency": "BRL",
      "marketPrice": "35.50",
      "collateralMarginRate": "7.1253",
      "riskPositionValueLong": {
        "amount": "150000.00",
        "currency": "BRL"
      },
      "riskPositionValueShort": {
        "amount": "250000.00",
        "currency": "BRL"
      }
    }
  ]
}
