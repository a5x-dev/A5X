  "title" : "Margin Positions Details",
  "description" : "Message providing details about margin and collateral positions",
  "type" : "object",
  "properties" : {
    "triggerResult" : {
      "$ref" : "../../objects/business/TriggerResult.json",
      "description" : "Details of the trigger for the risk calculation"
    },
    "clearingMemberIdentification" : {
      "$ref" : "../../objects/business/PartyId.json",
      "description" : "Identification of the clearing member"
    },
    "participantIdentification" : {
      "$ref" : "../../objects/business/PartyId.json",
      "description" : "Identification of the participant"
    },
    "accountIdentification" : {
      "$ref" : "../../objects/business/AccountIdentification.json",
      "description" : "Identification of the account"
    },
    "currency" : {
      "$ref" : "../../objects/business/ExternalCodeTextList.json",
      "description" : "Currency code in which the amount is denominated",
      "$comment" : "Consult External Code List table ExternalCurrencyCode"
    },
    "collateralPosition" : {
      "type": "array",
       "items": {
      "$ref" : "../../objects/business/RiskCollateralPosition.json"
