{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:business:SecuritiesCollateralResponse",
  "$metadata" : {
    "domain" : "business",
    "schemaId" : "urn:a5x:ex5:schema:v1:business:SecuritiesCollateralResponse"
  },
  "title" : "Securities Collateral Transfer Response",
  "description" : "Provides details on the securities collateral proposal.",
  "type" : "object",
  "properties" : {
    "collateralIdentification" : {
      "type" : "string",
      "maxLength" : 35,
      "minLength" : 1,
      "description" : "Collateral identification as known by party. Its identification is generated by the requesting party"
    },
    "quantity" : {
      "$ref" : "../../types/PositiveInteger.json",
      "description" : "Quantity requested to the distribution with command."
    },
    "collateralValue" : {
      "$ref" : "../../objects/business/MonetaryValue.json",
      "description" : "Collateral value in active currency"
    },
    "collateralStatus" : {
      "$ref" : "../../objects/business/CollateralStatus.json",
      "description" : "This block contains information on the status of each collateral processing"
    }
  },
  "required" : [ "collateralIdentification", "quantity", "collateralValue", "collateralStatus" ],
  "additionalProperties" : false,
  "examples" : [ {
    "collateralIdentification" : "CASH-REF-001",
    "quantity" : 100,
    "collateralValue" : {
      "currency" : "BRL",
      "amount" : "100000.00"
    },
    "collateralStatus" : {
      "statusCode" : 1,
      "errorIdentification" : [ {
        "code" : "TEC00000",
        "message" : "Error X",
        "errorDescription" : "COD12452",
        "refId" : "REF12345"
      } ]
    }
  } ]
}