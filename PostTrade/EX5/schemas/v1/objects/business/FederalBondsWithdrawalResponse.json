{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:business:FederalBondsWithdrawalResponse",
  "$metadata" : {
    "domain" : "business",
    "schemaId" : "urn:a5x:ex5:schema:v1:business:FederalBondsWithdrawalResponse"
  },
  "title" : "Other Collateral Transfer Response",
  "description" : "Provides details on the other collateral proposal",
  "type" : "object",
  "properties" : {
    "collateralIdentification" : {
      "type" : "string",
      "maxLength" : 35,
      "minLength" : 1,
      "description" : "Collateral identification as known by party. Its identification is generated by the requesting party"
    },
    "quantity" : {
      "$ref" : "../../types/PositiveInteger.json",
      "description" : "Quantity requested to collateral transfer"
    },
    "collateralValue" : {
      "$ref" : "../../objects/business/MonetaryValue.json",
      "description" : "Collateral value in active currency"
    },
    "selicOperationCode" : {
      "type" : "string",
      "maxLength" : 6,
      "minLength" : 1,
      "description" : "SELIC operation code for federal bond transactions",
      "examples" : [ "65499", "12345", "98765" ]
    },
    "assignerAccount" : {
      "type" : "string",
      "maxLength" : 35,
      "description" : "Provides assigner account identification",
      "examples" : [ "ASSIGNER-ACC-001", "ACC123456789" ]
    },
    "assigneeAccount" : {
      "type" : "string",
      "maxLength" : 35,
      "description" : "Provides identification about assignee account",
      "examples" : [ "ASSIGNEE-ACC-001", "ACC987654321" ]
    },
    "collateralStatus" : {
      "$ref" : "../../objects/business/CollateralStatus.json",
      "description" : "This block contains information on the status of each collateral processing"
    }
  },
  "required" : [ "collateralIdentification", "quantity", "collateralValue", "collateralStatus" ],
  "additionalProperties" : false,
  "examples" : [ {
    "collateralIdentification" : "CASH-REF-001",
    "quantity" : 100,
    "collateralValue" : {
      "currency" : "BRL",
      "amount" : "100000.00"
    },
    "selicOperationCode" : "65499",
    "assignerAccount" : "ASSIGNER-ACC-001",
    "assigneeAccount" : "ASSIGNEE-ACC-001",
    "collateralStatus" : {
      "statusCode" : 1,
      "errorIdentification" : [ {
        "code" : "TEC00000",
        "message" : "Error X",
        "errorDescription" : "COD12452",
        "referenceIdentification" : "REF12345"
      } ]
    }
  } ]
}