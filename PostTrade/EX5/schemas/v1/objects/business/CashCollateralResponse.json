{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:business:CashCollateralResponse",
  "$metadata" : {
    "domain" : "business",
    "schemaId" : "urn:a5x:ex5:schema:v1:business:CashCollateralResponse"
  },
  "title" : "Cash Collateral Transfer Response",
  "description" : "Provides details on the cash collateral proposal.",
  "type" : "object",
  "properties" : {
    "collateralIdentification" : {
      "type" : "string",
      "maxLength" : 35,
      "minLength" : 1,
      "description" : "Collateral identification as known by party. Its identification is generated by the requesting party"
    },
    "operationValue" : {
      "$ref" : "../../objects/business/MonetaryValue.json",
      "description" : "Amount requested to the distribution with command"
    },
    "collateralValue" : {
      "$ref" : "../../objects/business/MonetaryValue.json",
      "description" : "Collateral value in active currency"
    },
    "statusCode" : {
      "$ref" : "../../objects/business/ExternalCodeList.json",
      "description" : "Provides a proprietary status of each processing requested",
      "comment" : "Consult External Code List table ExternalCollateralStatusCode"
    },
    "errorIdentification" : {
      "type" : "array",
      "description" : "List of error identification rules when status indicates failure",
      "items" : {
        "$ref" : "../../objects/tech/StatusError.json"
      }
    }
  },
  "required" : [ "collateralIdentification", "operationValue", "collateralValue", "statusCode" ],
  "additionalProperties" : false,
  "examples" : [ {
    "collateralIdentification" : "CASH-REF-001",
    "operationValue" : {
      "currency" : "BRL",
      "amount" : "100000.00"
    },
    "collateralValue" : {
      "currency" : "BRL",
      "amount" : "100000.00"
    },
    "statusCode" : 1,
    "errorIdentification" : [ {
      "code" : "TEC00000",
      "message" : "Error X",
      "errorDescription" : "COD12452",
      "refId" : "REF12345"
    } ]
  } ]
}