{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:business:CollateralWithdrawalRequest",
  "$metadata" : {
    "domain" : "business",
    "schemaId" : "urn:a5x:ex5:schema:v1:business:CollateralWithdrawalRequest"
  },
  "title" : "Collateral Withdrawal Request Detail",
  "description" : "Provides details about the collateral withdrawal request",
  "type" : "object",
  "properties" : {
    "collateralIdentification" : {
      "type" : "string",
      "maxLength" : 35,
      "minLength" : 1,
      "description" : "Collateral ID given by the requestor participant"
    },
    "securitiesCollateral" : {
      "type" : "array",
      "description" : "Securities collateral items for transfer approval",
      "items" : {
        "allOf" : [ {
          "$ref" : "../../objects/business/SecuritiesCollateralOperation.json"
        }, {
          "required" : [ "collateralIdentification", "assetNumber", "quantity", "custodianInformationDestination", "centralDepositaryOperationNumber" ]
        } ]
      },
      "minItems" : 1,
      "maxItems" : 60
    },
    "cashCollateral" : {
      "type" : "array",
      "description" : "Cash collateral items for transfer approval",
      "items" : {
        "allOf" : [ {
          "$ref" : "../../objects/business/CashCollateralMovement.json"
        }, {
          "properties" : {
            "executedMovementType" : {
              "$ref" : "../../objects/business/ExternalCodeList.json",
              "description" : "Executed movement type for collateral operations",
              "$comment" : "Consult External Code List table ExternalCollateralExecutedMovementTypeCode"
            }
          }
        }, {
          "required" : [ "collateralIdentification", "assetNumber", "operationValue", "executedMovementType" ]
        } ]
      },
      "minItems" : 1,
      "maxItems" : 60,
      "additionalProperties": true
    },
    "federalBonds" : {
      "type" : "array",
      "description" : "Other types of collateral for transfer approval",
      "items" : {
        "allOf" : [ {
          "$ref" : "../../objects/business/OtherCollateralOperation.json"
        }, {
          "required" : [ "collateralIdentification", "assetNumber", "quantity" ]
        } ]
      },
      "minItems" : 1,
      "maxItems" : 60
    },
    "externalSecurities" : {
      "type" : "array",
      "description" : "Other types of collateral for transfer approval",
      "items" : {
        "$ref" : "../../objects/business/ExternalSecurities.json"
      },
      "minItems" : 1,
      "maxItems" : 60
    }
  },
  "required" : [ "collateralIdentification" ],
  "anyOf" : [ {
    "required" : [ "securitiesCollateral" ]
  }, {
    "required" : [ "cashCollateral" ]
  }, {
    "required" : [ "federalBonds" ]
  }, {
    "required" : [ "externalSecurities" ]
  } ],
  "additionalProperties" : true,
  "examples" : []
}
