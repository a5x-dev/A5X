{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:business:CollateralDepositArrayItem",
  "$metadata" : {
    "domain" : "business",
    "schemaId" : "urn:a5x:ex5:schema:v1:business:CollateralDepositArrayItem"
  },
  "title" : "Collateral Transfer Details",
  "description" : "Collateral transfer details with different types of collateral using anyOf pattern",
  "type" : "object",
  "properties" : {
    "securitiesCollateralProposal" : {
      "type" : "array",
      "description" : "Securities collateral items for deposit proposal",
      "items" : {
        "$ref" : "../../objects/business/SecuritiesCollateralProposal.json"
      },
      "minItems" : 1,
      "maxItems" : 60
    },
    "cashCollateralProposal" : {
      "type" : "array",
      "description" : "Cash collateral items for deposit proposal",
      "items" : {
        "$ref" : "../../objects/business/CashCollateralProposal.json"
      },
      "minItems" : 1,
      "maxItems" : 60
    },
    "federalBondCollateral" : {
      "type" : "array",
      "description" : "Other types of collateral for deposit proposal",
      "items" : {
        "$ref" : "../../objects/business/federalBondCollateral.json"
      },
      "minItems" : 1,
      "maxItems" : 60
    },
    "externalSecurities" : {
      "type" : "array",
      "description" : "This block provides information about external securities collateral valuation",
      "items" : {
        "$ref" : "../../objects/business/ExternalSecurities.json"
      },
      "minItems" : 1,
      "maxItems" : 60
    }
  },
  "anyOf" : [ {
    "properties" : {
      "securitiesCollateralProposal" : true
    },
    "required" : [ "securitiesCollateralProposal" ]
  }, {
    "properties" : {
      "cashCollateralProposal" : true
    },
    "required" : [ "cashCollateralProposal" ]
  }, {
    "properties" : {
      "federalBondCollateral" : true
    },
    "required" : [ "federalBondCollateral" ]
  }, {
    "properties" : {
      "externalSecurities" : true
    },
    "required" : [ "externalSecurities" ]
  } ],
  "additionalProperties" : false,
  "examples" : []
}
