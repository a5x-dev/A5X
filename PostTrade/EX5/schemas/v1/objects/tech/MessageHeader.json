{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:a5x:ex5:schema:v1:tech:MessageHeader",
  "$metadata": {
    "domain": "tech",
    "schemaId": "urn:a5x:ex5:schema:v1:tech:MessageHeader"
  },
  "title": "Header Message",
  "description": "Header Description",
  "type": "object",
  "properties": {
    "businessMessageIdentification": {
      "$ref": "#/$defs/businessMessageIdentification"
    },
    "businessMessage": {
      "$ref": "#/$defs/businessMessage"
    },
    "timestamp": {
      "$ref": "#/$defs/timestamp"
    },
    "from": {
      "$ref": "#/$defs/from"
    },
    "to": {
      "$ref": "#/$defs/to"
    },
    "sender": {
      "$ref": "#/$defs/sender"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "beginString": {
      "$ref": "#/$defs/beginString"
    }
  },
  "$defs": {
    "businessMessageIdentification": {
      "$ref": "../../objects/tech/MessageIdentifier.json"
    },
    "businessMessage": {
      "type": "string",
      "description": "Message type in our catalog",
      "examples": [
        "ex5-tec-hdr-0101"
      ]
    },
    "timestamp": {
      "type": "string",
      "description": "Trade Date and Time in ISO 8601 format",
      "format": "date-time",
      "examples": [
        "2026-03-14T00:00:00Z"
      ],
      "pattern": "^(([0-9]{4})((-[0-9]{2}){2}(([ T])?([0-9]{2}:){2}[0-9]{2}((\\+[0-9]{2}(:[0-9]{2})?)|Z)?)?|(-W[0-9]{2}(-[1-7])?)|(-[1-3]?[0-9]{2})))$"
    },
    "from": {
      "$ref": "../business/PartyId.json"
    },
    "to": {
      "$ref": "../business/PartyId.json"
    },
    "sender": {
      "$ref": "../tech/SenderSessionIdentifier.json"
    },
    "target": {
      "$ref": "../tech/TargetSessionIdentifier.json"
    },
    "beginString": {
      "type": "string",
      "description": "Session",
      "examples": [
        "FIX4.4"
      ]
    }
  },
  "required": [
    "businessMessageIdentification",
    "businessMessage",
    "timestamp",
    "from",
    "to",
    "sender",
    "target"
  ],
  "examples": [
    {
      "messageHeader": {
        "businessMessageIdentification": "5I000123202603020000000000000100000",
        "businessMessage": "ex5-col-wtd-1901",
        "timestamp": "2026-03-02T18:14:02.399Z",
        "from": {
          "id": 789012,
          "category": 3
        },
        "to": {
          "id": 555,
          "category": 55
        },
        "sender": {
          "CompID": "C000114ALC003"
        },
        "target": {
          "CompID": "GTWA5XD003"
        },
        "beginString": "FIX.4.4"
      }
    }
  ]
}