{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:a5x:ex5:schema:v1:collateral:ex5-col-umb-18",
  "$metadata": {
    "domain": "collateral",
    "schemaId": "urn:a5x:ex5:schema:v1:collateral:ex5-col-umb-18"
  },
  "title": "Collateral Umbrella Distribution Status",
  "description": "Status message for collateral umbrella type distribution operations",
  "type": "object",
  "properties": {
    "transactionIdentification": {
      "$ref": "../../objects/business/TransactionIdentification.json",
      "description": "Provides details about unique transaction identification known by the participant"
    },
    "clearingMemberIdentification": {
      "$ref": "../../objects/business/PartyId.json",
      "description": "Provides details about the clearing member identification"
    },
    "participantIdentification": {
      "$ref": "../../objects/business/PartyId.json",
      "description": "Provides details about the participant identification"
    },
    "collateralDetails": {
      "type": "array",
      "description": "Provides details about the umbrella type distribution.",
      "items": {
        "$ref": "../../objects/business/CollateralStatusItem.json"
      }
    },
    "collateralUmbrellaStatus": {
      "$ref": "../../objects/business/CollateralStatus.json",
      "description": "Overall status of the collateral umbrella distribution request"
    }
  },
  "required": [
    "transactionIdentification", "clearingMemberIdentification"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "transactionIdentification": "UMB-STA-220915-1000",
      "clearingMemberIdentification": {
        "id": 123456,
        "category": 2
      },
      "participantIdentification": {
        "id": 789012,
        "category": 3
      },
      "collateralDetails": [
        {
          "collateralIdentification": "2",
          "quantity": 2000,
          "operationValue": {
            "amount": "1000.00",
            "currency": "BRL"
          },
          "collateralValue": {
            "amount": "75000.00",
            "currency": "BRL"
          },
          "collateralStatus": {
            "statusCode": 1,
            "errorIdentification": [
              {
                "code": "TEC00000",
                "message": "Error X",
                "errorDescription": "COD12452",
                "referenceIdentification": "REF12345"
              }
            ]
          }
        }
      ],
      "collateralUmbrellaStatus": {
        "statusCode": 1,
        "errorIdentification": [
          {
            "code": "TEC00000",
            "message": "Error X",
            "errorDescription": "COD12452",
            "referenceIdentification": "REF12345"
          }
        ]
      }
    }
  ]
}