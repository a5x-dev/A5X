{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:types:Decimal18_17",
  "$metadata" : {
    "domain" : "types",
    "schemaId" : "urn:a5x:ex5:schema:v1:types:Decimal18_17"
  },
  "title" : "Decimal18_17",
  "description" : "Decimal number with up to 10 digits before decimal point and up to 9 decimal places",
  "type" : "string",
  "maxLength" : 20,
  "minLength" : 1,
  "pattern" : "^\\d{1,10}(\\.\\d{1,9})?$",
  "examples" : [ "1.5", "1234567890.123456789", "100.99" ]
}