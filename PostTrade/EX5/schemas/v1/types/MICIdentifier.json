{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:types:MICIdentifier",
  "$metadata" : {
    "domain" : "types",
    "schemaId" : "urn:a5x:ex5:schema:v1:types:MICIdentifier"
  },
  "title" : "MIC Identifier",
  "description" : "Market Identifier Code as per ISO 10383 standard",
  "type" : "string", 
  "minLength": 4,
  "maxLength": 4,
  "pattern": "^[A-Z0-9]{4}$",
  "examples" : [ "A5XB", "XNYS", "XNAS" ],
  "default" : "A5XB"
}